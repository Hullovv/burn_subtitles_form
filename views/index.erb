<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Видео Сервис - Прожиг субтитров с предпросмотром</title>
    <link rel="stylesheet" href="/css/index.css">
</head>
<body>
    <div class="wrapper">
        <div class="container">
            <div class="header">
                <h1>🎬 Прожиг субтитров в видео</h1>
                <p>Предпросмотр всех эффектов с поиском шрифтов</p>
            </div>

            <div class="main-content">
                <!-- Левая колонка - форма -->
                <div class="form-container">
                    <form action="/burn" method="post" enctype="multipart/form-data" id="burnForm">
                        <div class="form-group">
                            <label>📹 URL видео файла</label>
                            <input type="url" name="video_url"
                                placeholder="https://example.com/video.mp4"
                                required>
                        </div>

                        <div class="form-group">
                            <label>📝 Файл субтитров</label>
                            <input type="file" name="subtitle_file"
                                accept=".srt,.vtt,.ass,.ssa,.txt"
                                id="subtitleFile">
                            <div class="help-text">Загрузите файл для отображения в предпросмотре</div>
                        </div>

                        <div class="settings-panel">
                            <h3 style="margin-bottom: 15px; color: #667eea;">⚙️ Настройки субтитров</h3>
                            <div class="row">
                                <div>
                                    <label>🔍 Поиск шрифта</label>
                                    <div class="font-search-container">
                                        <input type="text" id="fontSearch" class="font-search-input"
                                            placeholder="Введите название шрифта..." autocomplete="off">
                                        <div id="fontList" class="font-select-custom"></div>
                                    </div>
                                    <input type="hidden" name="font" id="selectedFont" value="Arial">
                                    <div class="selected-font-display" id="selectedFontDisplay">
                                        Выбран: <strong>Arial</strong>
                                    </div>
                                </div>
                                <div>
                                    <label>Размер</label>
                                    <input type="number" name="font_size" id="fontSize" value="24" min="10" max="60" step="2">
                                </div>
                                <div>
                                    <label>Цвет текста</label>
                                    <select name="primary_colour" id="textColor">
                                        <option value="&H00FFFFFF">⚪ Белый</option>
                                        <option value="&H0000FFFF">🟡 Желтый</option>
                                        <option value="&H00FF0000">🔴 Красный</option>
                                        <option value="&H0000FF00">🟢 Зеленый</option>
                                        <option value="&H000000FF">🔵 Синий</option>
                                        <option value="&H00FF00FF">🟣 Фиолетовый</option>
                                        <option value="&H0000FFFF">🟠 Оранжевый</option>
                                    </select>
                                </div>
                                <div>
                                    <label>📝 Контур (0-5)</label>
                                    <input type="range" id="outline" name="outline" min="0" max="5" value="1" step="1">
                                    <div class="help-text">Значение: <span id="outlineValue">1</span> <span id="outlineStatus"></span></div>
                                </div>
                                <div>
                                    <label>🌑 Тень (0-6)</label>
                                    <input type="range" id="shadow" name="shadow" min="0" max="6" value="2" step="1">
                                    <div class="help-text">Значение: <span id="shadowValue">2</span> <span id="shadowStatus"></span></div>
                                </div>
                            </div>
                        </div>

                        <button type="submit" id="submitBtn">
                            🔥 Прожечь субтитры
                        </button>
                    </form>
                </div>

                <!-- Правая колонка - предпросмотр -->
                <div class="preview-container">
                    <div class="preview-box" id="previewBox">
                        <div class="preview-label">
                            🎨 Предпросмотр субтитров (применены все эффекты)
                        </div>
                        <div id="previewSubtitle" class="preview-subtitle">
                            <div id="subtitleText" style="transition: all 0.2s;">
                                Загрузите файл субтитров<br>
                                или выберите пример ниже
                            </div>
                        </div>

                        <!-- Выбор фона -->
                        <div class="background-controls">
                            <label>🎨 Выбор фона для предпросмотра:</label>
                            <div class="bg-options">
                                <div class="bg-option" data-bg="black" onclick="setBackground('black')">
                                    <div class="bg-preview" style="background: #000;"></div>
                                    <div>Черный</div>
                                </div>
                                <div class="bg-option" data-bg="white" onclick="setBackground('white')">
                                    <div class="bg-preview" style="background: #fff; border: 1px solid #ddd;"></div>
                                    <div>Белый</div>
                                </div>
                                <div class="bg-option" data-bg="gradient" onclick="setBackground('gradient')">
                                    <div class="bg-preview" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);"></div>
                                    <div>Градиент</div>
                                </div>
                                <div class="bg-option" data-bg="video" onclick="setBackground('video')">
                                    <div class="bg-preview" style="background: #4a4a4a; display: flex; align-items: center; justify-content: center; color: white; font-size: 10px;">🎬</div>
                                    <div>Видео</div>
                                </div>
                            </div>

                            <!-- Скрытый блок для видео фона -->
                            <div id="videoBackground" style="display: none; margin-top: 10px;">
                                <input type="url" id="bgVideoUrl" placeholder="https://example.com/video.mp4" style="width: 100%; padding: 8px; border: 1px solid #ddd; border-radius: 5px;">
                                <button type="button" onclick="loadVideoBackground()" style="margin-top: 5px; padding: 5px; font-size: 12px;">Загрузить видео фон</button>
                            </div>
                        </div>

                        <div class="sample-texts">
                            <div class="sample-btn" onclick="setSampleText('Это пример субтитров с тенью и контуром')">📝 Пример 1</div>
                            <div class="sample-btn" onclick="setSampleText('Настройки применяются в реальном времени')">⚡ Пример 2</div>
                            <div class="sample-btn" onclick="setSampleText('Шрифт: ' + document.getElementById('selectedFont').value)">🎨 Пример 3</div>
                            <div class="sample-btn" onclick="loadFirstSubtitle()">📄 Показать из файла</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="loader" id="loader">
        <div class="spinner"></div>
        <div>⏳ Скачивание и обработка видео...</div>
        <div>Пожалуйста, не закрывайте страницу</div>
    </div>

    <script src="/js/script.js"></script>
</body>
</html>
